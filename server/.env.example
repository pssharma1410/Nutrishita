PORT=5050
MONGO_URI=mongodb://127.0.0.1:27017/nutrishita

# Gmail: use an App Password (Google Account → Security → 2-Step → App passwords)
EMAIL_USER=yourgmail@gmail.com
EMAIL_PASS=your_app_password

# Receives new-booking alerts (defaults to EMAIL_USER if omitted)
ADMIN_EMAIL=admin@yourdomain.com

# Browser origin for CORS
CLIENT_ORIGIN=http://localhost:5174

# Video / telehealth link shown in emails (placeholder until Zoom/Google Meet integration)
DEFAULT_MEETING_LINK=https://meet.example.com/nutrishita-consultation

# Optional Google Calendar integration for unique Google Meet links per booking
# If these are missing, app falls back to DEFAULT_MEETING_LINK
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REFRESH_TOKEN=
GOOGLE_CALENDAR_ID=primary
GOOGLE_CALENDAR_TIMEZONE=Asia/Kolkata

# Optional: From name in emails
BRAND_NAME=Nutrishita by Akshita

# Future payments (see /api/future/*)
# PAYMENT_PROVIDER=stripe
